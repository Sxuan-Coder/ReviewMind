APP_NAME=ReviewMind API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173"]
GITHUB_TOKEN=your_github_token_here
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=10

LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://ai.sxuan.top/v1
LLM_MODEL_SUMMARY=glm-5.1
LLM_MODEL_REVIEW=glm-5.1
LLM_TIMEOUT_SECONDS=60
LLM_MOCK_MODE=false

# PostgreSQL + pgvector（默认）
DATABASE_URL=postgresql+asyncpg://reviewmind:reviewmind@localhost:5432/reviewmind
# 本地无 PostgreSQL 时，可切回 SQLite：
# DATABASE_URL=sqlite+aiosqlite:///./reviewmind.db

# Redis（可选，不配置则自动降级为无缓存）
REDIS_URL=redis://localhost:6379/0

# Embedding 配置（用于 pgvector 向量检索）
# 方式一：付费/自建 OpenAI 兼容服务
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://ai.sxuan.top/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 方式二：Gitee Serverless 免费向量大模型（推荐，无需付费）
# 模型 Qwen3-Embedding-8B 固定输出 1024 维，需在 DATABASE_URL 用 pgvector 重建索引
# EMBEDDING_API_KEY=your_gitee_access_token_here
# EMBEDDING_API_BASE=https://ai.gitee.com/v1
# EMBEDDING_MODEL=Qwen3-Embedding-8B
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_EXTRA_HEADERS={"X-Failover-Enabled":"true"}